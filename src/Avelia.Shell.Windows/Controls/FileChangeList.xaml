<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Avelia.Shell.Windows.Controls.FileChangeList"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Avelia.Shell.Windows.ViewModels"
    xmlns:controls="using:Avelia.Shell.Windows.Controls"
>
    <UserControl.Resources>
        <DataTemplate x:Key="FileRowTemplate" x:DataType="vm:DiffFileViewModel">
            <!--
                Outer Grid owns the focus tint (fills the row edge-to-edge);
                inner Grid owns the padded content. Two-layer split avoids
                the negative-margin trick (which couples to the inner
                Padding) — if a future tweak changes Padding, the underlay
                still spans correctly.
            -->
            <Grid>
                <!-- Focused-row tint underlay -->
                <Border
                    Background="{ThemeResource AveliaSubtleFillSecondaryBrush}"
                    Visibility="{x:Bind IsFocused, Mode=OneWay, FallbackValue=Collapsed}"
                />

                <Grid Padding="14,8" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                <!-- M / A / D / R badge -->
                <Border
                    Grid.Column="0"
                    Width="18"
                    Height="18"
                    CornerRadius="{StaticResource AveliaCornerRadiusSmall}"
                    Background="{ThemeResource AveliaSubtleFillTertiaryBrush}"
                    BorderBrush="{ThemeResource AveliaSurfaceStrokeBrush}"
                    BorderThickness="1"
                    VerticalAlignment="Center"
                >
                    <TextBlock
                        FontFamily="{StaticResource AveliaUiFontFamily}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource AveliaTextSecondaryBrush}"
                        Text="{x:Bind KindBadge, Mode=OneTime, FallbackValue=''}"
                    />
                </Border>

                <!-- Folder + filename (single mono run, two TextBlocks) -->
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="0"
                    VerticalAlignment="Center"
                >
                    <TextBlock
                        Style="{StaticResource AveliaMonoCaptionTextStyle}"
                        Foreground="{ThemeResource AveliaTextTertiaryBrush}"
                        Text="{x:Bind Folder, Mode=OneTime, FallbackValue=''}"
                        TextTrimming="CharacterEllipsis"
                    />
                    <TextBlock
                        Style="{StaticResource AveliaMonoCaptionTextStyle}"
                        Foreground="{ThemeResource AveliaTextPrimaryBrush}"
                        Text="{x:Bind FileName, Mode=OneTime, FallbackValue=''}"
                        TextTrimming="CharacterEllipsis"
                    />
                </StackPanel>

                <controls:Chip
                    Grid.Column="2"
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"
                    FillBrush="{ThemeResource AveliaDiffAddBgBrush}"
                    StrokeBrush="{ThemeResource AveliaDiffAddStrongBrush}"
                    TextBrush="{ThemeResource AveliaSuccessBrush}"
                    Text="{x:Bind AddDisplay, Mode=OneTime, FallbackValue=''}"
                />
                <controls:Chip
                    Grid.Column="3"
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"
                    FillBrush="{ThemeResource AveliaDiffDelBgBrush}"
                    StrokeBrush="{ThemeResource AveliaDiffDelStrongBrush}"
                    TextBrush="{ThemeResource AveliaDangerBrush}"
                    Text="{x:Bind DelDisplay, Mode=OneTime, FallbackValue=''}"
                />

                <FontIcon
                    Grid.Column="4"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="10"
                    Glyph="&#xE76C;"
                    Foreground="{ThemeResource AveliaTextTertiaryBrush}"
                    VerticalAlignment="Center"
                />
                </Grid>
            </Grid>
        </DataTemplate>

    </UserControl.Resources>

    <ListView
        x:Name="FilesList"
        AutomationProperties.AutomationId="PrFileList"
        AutomationProperties.Name="Pull request file list"
        ItemsSource="{x:Bind Files, Mode=OneWay}"
        ItemTemplate="{StaticResource FileRowTemplate}"
        ItemContainerStyle="{StaticResource AveliaPlainInteractiveListItemContainerStyle}"
        IsItemClickEnabled="True"
        ItemClick="OnFileItemClick"
        SelectionMode="None"
        Background="Transparent"
        BorderThickness="0"
        Padding="0"
        HorizontalContentAlignment="Stretch"
        ScrollViewer.HorizontalScrollMode="Disabled"
        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
        ScrollViewer.VerticalScrollBarVisibility="Auto"
    />
</UserControl>
