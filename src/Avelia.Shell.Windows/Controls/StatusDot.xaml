<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Avelia.Shell.Windows.Controls.StatusDot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:Avelia.Shell.Windows.Converters"
>
    <UserControl.Resources>
        <conv:WorkspaceStatusToBrushConverter x:Key="StatusBrush" />
        <conv:WorkspaceStatusToLabelConverter x:Key="StatusLabel" />
    </UserControl.Resources>

    <Ellipse
        x:Name="Dot"
        Width="8"
        Height="8"
        Fill="{x:Bind Status, Converter={StaticResource StatusBrush}, Mode=OneWay}"
        ToolTipService.ToolTip="{x:Bind Status, Converter={StaticResource StatusLabel}, Mode=OneWay}"
    />
</UserControl>
