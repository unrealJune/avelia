<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Avelia.Shell.Windows.Controls.Composer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Avelia.Shell.Windows.Controls"
>
    <!--
        Bottom-anchored composer. Multi-line TextBox up top (Shift+Enter for
        newline, Enter submits via KeyDown handler), toolbar row below with
        model badge, link button, attachments, tools, and the accent Send.
        Matches workspace-view.jsx :: composer.
    -->
    <Border
        Background="{ThemeResource AveliaCardBackgroundBrush}"
        BorderBrush="{ThemeResource AveliaSurfaceStrokeBrush}"
        BorderThickness="1"
        CornerRadius="{StaticResource AveliaCornerRadiusLarge}"
        Padding="12,8"
    >
        <Grid RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBox
                x:Name="MessageInput"
                Grid.Row="0"
                AcceptsReturn="True"
                AutomationProperties.Name="Message composer"
                BorderThickness="0"
                Background="Transparent"
                FontSize="14"
                MinHeight="56"
                MaxHeight="200"
                PlaceholderText="Send a message…"
                TextWrapping="Wrap"
                Text="{x:Bind Text, Mode=TwoWay, FallbackValue=''}"
                PreviewKeyDown="OnInputPreviewKeyDown"
            />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <local:ModelBadge
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    ModelName="{x:Bind ModelName, Mode=OneWay, FallbackValue='Sonnet 4.5'}"
                />

                <Button
                    Grid.Column="1"
                    AutomationProperties.Name="Link issue"
                    Style="{StaticResource AveliaSubtleButtonStyle}"
                    Padding="8,4"
                    FontSize="12"
                >
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe Fluent Icons" FontSize="12" Glyph="&#xE71B;" />
                        <TextBlock Text="Link issue" />
                    </StackPanel>
                </Button>

                <Button
                    Grid.Column="3"
                    AutomationProperties.Name="Attach"
                    Style="{StaticResource AveliaIconButtonStyle}"
                    Margin="0,0,4,0"
                >
                    <FontIcon FontFamily="Segoe Fluent Icons" FontSize="14" Glyph="&#xE723;" />
                </Button>

                <Button
                    Grid.Column="4"
                    AutomationProperties.Name="Tools"
                    Style="{StaticResource AveliaIconButtonStyle}"
                    Margin="0,0,8,0"
                >
                    <FontIcon FontFamily="Segoe Fluent Icons" FontSize="14" Glyph="&#xE90F;" />
                </Button>

                <Button
                    x:Name="SendButton"
                    Grid.Column="5"
                    AutomationProperties.Name="Send message"
                    Style="{StaticResource AveliaAccentButtonStyle}"
                    Command="{x:Bind SendCommand, Mode=OneWay}"
                >
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Send" />
                        <FontIcon FontFamily="Segoe Fluent Icons" FontSize="12" Glyph="&#xE724;" />
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
