<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Avelia.Shell.Windows.Pages.SettingsSubpages.ProfileSubpage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Avelia.Shell.Windows.ViewModels"
>
    <ScrollViewer
        Padding="4,4,4,16"
        HorizontalScrollMode="Disabled"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto"
    >
        <StackPanel Spacing="12">
            <Border
                Background="{ThemeResource AveliaCardBackgroundBrush}"
                BorderBrush="{ThemeResource AveliaSurfaceStrokeBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource AveliaCornerRadiusMedium}"
                Padding="20,18"
            >
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Avatar — initials on accent fill -->
                    <Border
                        Grid.Column="0"
                        Width="56"
                        Height="56"
                        CornerRadius="999"
                        Background="{ThemeResource AveliaAccentDefaultBrush}"
                    >
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource AveliaUiFontFamily}"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource AveliaTextOnAccentBrush}"
                            Text="{x:Bind ViewModel.Initials, Mode=OneWay, FallbackValue=''}"
                        />
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock
                            Style="{StaticResource AveliaBodyLargeTextStyle}"
                            Text="{x:Bind ViewModel.DisplayName, Mode=OneWay, FallbackValue=''}"
                        />
                        <TextBlock
                            Style="{StaticResource AveliaCaptionTextStyle}"
                            Foreground="{ThemeResource AveliaTextSecondaryBrush}"
                            Text="{x:Bind ViewModel.Email, Mode=OneWay, FallbackValue=''}"
                        />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        AutomationProperties.Name="Manage account"
                        Style="{StaticResource AveliaSubtleButtonStyle}"
                        IsEnabled="False"
                    >
                        Manage account
                    </Button>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
