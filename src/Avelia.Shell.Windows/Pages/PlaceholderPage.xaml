<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Avelia.Shell.Windows.Pages.PlaceholderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
    <!--
        Holding page for sections that haven't been built yet (Inbox, Pinned,
        History, Archive, Settings). Replaced section by section in later chunks.
    -->
    <Grid Padding="32">
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8"
            MaxWidth="480"
        >
            <TextBlock
                x:Name="PageTitle"
                AutomationProperties.AutomationId="PlaceholderPageTitle"
                Style="{StaticResource AveliaTitleTextStyle}"
                HorizontalAlignment="Center"
                Text="Coming soon"
            />
            <TextBlock
                x:Name="PageSubtitle"
                Style="{StaticResource AveliaBodyTextStyle}"
                Foreground="{ThemeResource AveliaTextSecondaryBrush}"
                HorizontalAlignment="Center"
                TextAlignment="Center"
                TextWrapping="Wrap"
                Text="This section ships in a future chunk."
            />
        </StackPanel>
    </Grid>
</Page>
