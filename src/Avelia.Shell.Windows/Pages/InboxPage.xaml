<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Avelia.Shell.Windows.Pages.InboxPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Avelia.Shell.Windows.Controls"
    xmlns:vm="using:Avelia.Shell.Windows.ViewModels"
>
    <Page.Resources>
        <!--
            One inbox-row template per kind (Warning / Success / Info). The
            split-by-template pattern keeps the leading tile's brushes as
            inline {ThemeResource} references — a converter approach would
            freeze the resolved brush at first paint and miss theme switches
            (the regression class ThemeUsageLintTests guards). The shared
            body below the tile lives in InboxItemRowBody so a layout tweak
            is a one-file change.
        -->
        <DataTemplate x:Key="InboxRowWarningTemplate" x:DataType="vm:InboxItemViewModel">
            <Grid Padding="14,12" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Width="36"
                    Height="36"
                    VerticalAlignment="Top"
                    CornerRadius="{StaticResource AveliaCornerRadiusSmall}"
                    Background="{ThemeResource AveliaWarningBgBrush}"
                >
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        FontSize="16"
                        Glyph="&#xE7BA;"
                        Foreground="{ThemeResource AveliaWarningBrush}"
                    />
                </Border>
                <controls:InboxItemRowBody Grid.Column="1" Item="{x:Bind}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="InboxRowSuccessTemplate" x:DataType="vm:InboxItemViewModel">
            <Grid Padding="14,12" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Width="36"
                    Height="36"
                    VerticalAlignment="Top"
                    CornerRadius="{StaticResource AveliaCornerRadiusSmall}"
                    Background="{ThemeResource AveliaSuccessBgBrush}"
                >
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        FontSize="16"
                        Glyph="&#xE73E;"
                        Foreground="{ThemeResource AveliaSuccessBrush}"
                    />
                </Border>
                <controls:InboxItemRowBody Grid.Column="1" Item="{x:Bind}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="InboxRowInfoTemplate" x:DataType="vm:InboxItemViewModel">
            <Grid Padding="14,12" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Width="36"
                    Height="36"
                    VerticalAlignment="Top"
                    CornerRadius="{StaticResource AveliaCornerRadiusSmall}"
                    Background="{ThemeResource AveliaInfoBgBrush}"
                >
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        FontSize="16"
                        Glyph="&#xE946;"
                        Foreground="{ThemeResource AveliaInfoBrush}"
                    />
                </Border>
                <controls:InboxItemRowBody Grid.Column="1" Item="{x:Bind}" />
            </Grid>
        </DataTemplate>

        <controls:InboxItemTemplateSelector
            x:Key="InboxRowSelector"
            WarningTemplate="{StaticResource InboxRowWarningTemplate}"
            SuccessTemplate="{StaticResource InboxRowSuccessTemplate}"
            InfoTemplate="{StaticResource InboxRowInfoTemplate}"
        />
    </Page.Resources>

    <!--
        Grid (Auto / *) rather than an outer ScrollViewer: the card fills the
        remaining height and the ListView scrolls inside it. Mirrors
        PrReviewPage's layout pattern and avoids the nested-ScrollViewer UX
        (outer + inner scrollbars on a long inbox).
    -->
    <Grid Padding="32,28,32,32" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            MaxWidth="820"
            HorizontalAlignment="Stretch"
            Orientation="Vertical"
            Spacing="4"
        >
            <TextBlock
                AutomationProperties.AutomationId="InboxPageTitle"
                Style="{StaticResource AveliaTitleTextStyle}"
                Text="Inbox"
            />
            <TextBlock
                AutomationProperties.AutomationId="InboxPageSubtitle"
                Style="{StaticResource AveliaBodyTextStyle}"
                Foreground="{ThemeResource AveliaTextSecondaryBrush}"
                Text="{x:Bind ViewModel.HeaderSubtitle, Mode=OneWay, FallbackValue=''}"
            />
        </StackPanel>

        <Border
            Grid.Row="1"
            MaxWidth="820"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="{ThemeResource AveliaCardBackgroundBrush}"
            BorderBrush="{ThemeResource AveliaSurfaceStrokeBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource AveliaCornerRadiusLarge}"
        >
            <ListView
                x:Name="ItemsList"
                AutomationProperties.AutomationId="InboxItemsList"
                AutomationProperties.Name="Inbox notifications"
                ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                ItemTemplateSelector="{StaticResource InboxRowSelector}"
                ItemContainerStyle="{StaticResource AveliaPlainInteractiveListItemContainerStyle}"
                IsItemClickEnabled="True"
                ItemClick="OnInboxItemClick"
                SelectionMode="None"
                Background="Transparent"
                BorderThickness="0"
                Padding="0"
                HorizontalContentAlignment="Stretch"
                ScrollViewer.HorizontalScrollMode="Disabled"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
            />
        </Border>
    </Grid>
</Page>
