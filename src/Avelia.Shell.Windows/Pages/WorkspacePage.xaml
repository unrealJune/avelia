<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Avelia.Shell.Windows.Pages.WorkspacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Avelia.Shell.Windows.Controls"
    xmlns:vm="using:Avelia.Shell.Windows.ViewModels"
>
    <Page.Resources>
        <ResourceDictionary>
            <!-- ============================================================
                 Conversation message templates (one per MessageViewModel kind)
                 ============================================================ -->

            <!-- 1) Agent message — body text with inline code-refs -->
            <DataTemplate x:Key="AgentMessageTemplate" x:DataType="vm:AgentMessageViewModel">
                <Border Padding="0,8,0,8">
                    <controls:CodeRefBlock
                        TextStyle="{StaticResource AveliaBodyTextStyle}"
                        TextWrapping="Wrap"
                        SourceText="{x:Bind Text, FallbackValue=''}"
                    />
                </Border>
            </DataTemplate>

            <!-- 2) Agent error — red banner with icon -->
            <DataTemplate x:Key="AgentErrorTemplate" x:DataType="vm:AgentErrorViewModel">
                <Border
                    Margin="0,4"
                    Background="{ThemeResource AveliaDangerBgBrush}"
                    BorderBrush="{ThemeResource AveliaDangerBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="{StaticResource AveliaCornerRadiusSmall}"
                    Padding="12,10"
                >
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            Grid.Column="0"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="14"
                            Glyph="&#xE783;"
                            Foreground="{ThemeResource AveliaDangerBrush}"
                            VerticalAlignment="Top"
                        />
                        <controls:CodeRefBlock
                            Grid.Column="1"
                            TextStyle="{StaticResource AveliaMonoBodyTextStyle}"
                            TextWrapping="Wrap"
                            TextForeground="{ThemeResource AveliaDangerBrush}"
                            SourceText="{x:Bind Text, FallbackValue=''}"
                        />
                    </Grid>
                </Border>
            </DataTemplate>

            <!-- 3) Tool-batch — collapsed strip with summary line -->
            <DataTemplate x:Key="ToolBatchTemplate" x:DataType="vm:ToolBatchViewModel">
                <Border
                    Margin="0,4"
                    Background="{ThemeResource AveliaSubtleFillTertiaryBrush}"
                    BorderBrush="{ThemeResource AveliaSurfaceStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource AveliaCornerRadiusSmall}"
                    Padding="10,8"
                >
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="13"
                            Glyph="&#xE74C;"
                            Foreground="{ThemeResource AveliaTextTertiaryBrush}"
                        />
                        <TextBlock
                            Style="{StaticResource AveliaCaptionTextStyle}"
                            FontFamily="{StaticResource AveliaMonoFontFamily}"
                            Foreground="{ThemeResource AveliaTextSecondaryBrush}"
                            Text="{x:Bind Summary, FallbackValue=''}"
                            VerticalAlignment="Center"
                        />
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="10"
                            Glyph="&#xE70D;"
                            Foreground="{ThemeResource AveliaTextTertiaryBrush}"
                        />
                    </StackPanel>
                </Border>
            </DataTemplate>

            <!-- 4) Change note — file path + diff chips -->
            <DataTemplate x:Key="ChangeNoteTemplate" x:DataType="vm:ChangeNoteViewModel">
                <Border
                    Margin="0,4"
                    Background="{ThemeResource AveliaCardBackgroundBrush}"
                    BorderBrush="{ThemeResource AveliaSurfaceStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource AveliaCornerRadiusSmall}"
                    Padding="12,9"
                >
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            Grid.Column="0"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="13"
                            Glyph="&#xE8A5;"
                            Foreground="{ThemeResource AveliaTextTertiaryBrush}"
                            VerticalAlignment="Center"
                        />
                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="0"
                        >
                            <TextBlock
                                Style="{StaticResource AveliaMonoCaptionTextStyle}"
                                Text="{x:Bind Folder, FallbackValue=''}"
                                Foreground="{ThemeResource AveliaTextTertiaryBrush}"
                            />
                            <TextBlock
                                Style="{StaticResource AveliaMonoCaptionTextStyle}"
                                Text="{x:Bind FileName, FallbackValue=''}"
                                Foreground="{ThemeResource AveliaTextPrimaryBrush}"
                            />
                        </StackPanel>
                        <controls:Chip
                            Grid.Column="2"
                            Margin="0,0,6,0"
                            FillBrush="{ThemeResource AveliaDiffAddBgBrush}"
                            StrokeBrush="{ThemeResource AveliaDiffAddStrongBrush}"
                            TextBrush="{ThemeResource AveliaSuccessBrush}"
                            Text="{x:Bind Add, Mode=OneTime, FallbackValue=''}"
                        />
                        <controls:Chip
                            Grid.Column="3"
                            FillBrush="{ThemeResource AveliaDiffDelBgBrush}"
                            StrokeBrush="{ThemeResource AveliaDiffDelStrongBrush}"
                            TextBrush="{ThemeResource AveliaDangerBrush}"
                            Text="{x:Bind Del, Mode=OneTime, FallbackValue=''}"
                        />
                    </Grid>
                </Border>
            </DataTemplate>

            <!-- 5) User message — bordered card -->
            <DataTemplate x:Key="UserMessageTemplate" x:DataType="vm:UserMessageViewModel">
                <Border
                    Margin="0,8,0,8"
                    HorizontalAlignment="Stretch"
                    Background="{ThemeResource AveliaCardBackgroundSecondaryBrush}"
                    BorderBrush="{ThemeResource AveliaSurfaceStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource AveliaCornerRadiusMedium}"
                    Padding="14,10"
                >
                    <StackPanel Spacing="6">
                        <TextBlock
                            Style="{StaticResource AveliaCaptionTextStyle}"
                            Foreground="{ThemeResource AveliaTextTertiaryBrush}"
                            Text="You"
                        />
                        <controls:CodeRefBlock
                            TextStyle="{StaticResource AveliaBodyTextStyle}"
                            TextWrapping="Wrap"
                            SourceText="{x:Bind Text, FallbackValue=''}"
                        />
                    </StackPanel>
                </Border>
            </DataTemplate>

            <!-- 6) Agent markdown — heading + body + numbered list -->
            <DataTemplate x:Key="AgentMarkdownTemplate" x:DataType="vm:AgentMarkdownViewModel">
                <StackPanel Padding="0,8,0,8" Spacing="10">
                    <TextBlock
                        Style="{StaticResource AveliaBodyStrongTextStyle}"
                        Visibility="{x:Bind HasHeading, Mode=OneTime}"
                        Text="{x:Bind Heading, FallbackValue=''}"
                    />
                    <TextBlock
                        Style="{StaticResource AveliaBodyTextStyle}"
                        TextWrapping="Wrap"
                        Text="{x:Bind Body, FallbackValue=''}"
                    />
                    <ItemsControl ItemsSource="{x:Bind Items, Mode=OneTime}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:AgentMarkdownListItem">
                                <Grid Margin="0,3" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse
                                        Grid.Column="0"
                                        Width="4"
                                        Height="4"
                                        Margin="2,9,0,0"
                                        VerticalAlignment="Top"
                                        Fill="{ThemeResource AveliaTextTertiaryBrush}"
                                    />
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock
                                            Style="{StaticResource AveliaBodyStrongTextStyle}"
                                            Text="{x:Bind Bold, FallbackValue=''}"
                                            TextWrapping="Wrap"
                                        />
                                        <TextBlock
                                            Style="{StaticResource AveliaBodyTextStyle}"
                                            Foreground="{ThemeResource AveliaTextSecondaryBrush}"
                                            Text="{x:Bind Detail, FallbackValue=''}"
                                            TextWrapping="Wrap"
                                        />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </DataTemplate>

            <!-- Selector wired to all six -->
            <controls:MessageTemplateSelector
                x:Key="MessageSelector"
                UserTemplate="{StaticResource UserMessageTemplate}"
                AgentTemplate="{StaticResource AgentMessageTemplate}"
                AgentErrorTemplate="{StaticResource AgentErrorTemplate}"
                ToolBatchTemplate="{StaticResource ToolBatchTemplate}"
                ChangeNoteTemplate="{StaticResource ChangeNoteTemplate}"
                AgentMarkdownTemplate="{StaticResource AgentMarkdownTemplate}"
            />
        </ResourceDictionary>
    </Page.Resources>

    <!-- Two-column workspace: center + right. Right column is a placeholder
         for Chunk 4 (PR header + file list + terminal). -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="420" />
        </Grid.ColumnDefinitions>

        <!-- =========== Center column =========== -->
        <Grid Grid.Column="0" Padding="24,16,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Pivot strip -->
            <controls:ChatPivot
                Grid.Row="0"
                Margin="0,0,0,8"
                Threads="{x:Bind ViewModel.Threads, Mode=OneWay}"
                ActiveThread="{x:Bind ViewModel.ActiveThread, Mode=TwoWay}"
            />

            <!-- Transcript: ListView for built-in UI virtualization. The
                 container style strips selection/hover chrome so it reads as
                 a plain stack of message blocks. -->
            <ListView
                Grid.Row="1"
                x:Name="ConversationList"
                AutomationProperties.AutomationId="ConversationList"
                ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}"
                ItemTemplateSelector="{StaticResource MessageSelector}"
                ItemContainerStyle="{StaticResource AveliaTranscriptItemContainerStyle}"
                SelectionMode="None"
                IsItemClickEnabled="False"
                ShowsScrollingPlaceholders="False"
                Background="Transparent"
                BorderThickness="0"
                Padding="0,8,0,8"
                HorizontalContentAlignment="Stretch"
                ScrollViewer.HorizontalScrollMode="Disabled"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
            />

            <!-- Composer. Command binding stays OneTime (default) — the
                 command instance never changes; only its CanExecute does, and
                 that's signalled via INotifyChanged on the command itself. -->
            <controls:Composer
                Grid.Row="2"
                Margin="0,8,0,0"
                AutomationProperties.AutomationId="Composer"
                Text="{x:Bind ViewModel.ComposerText, Mode=TwoWay}"
                SendCommand="{x:Bind ViewModel.SendMessageCommand}"
                ModelName="{x:Bind ViewModel.ModelName, Mode=OneWay, FallbackValue='Sonnet 4.5'}"
            />
        </Grid>

        <!-- =========== Right column: PR header + file list + terminal =========== -->
        <Grid
            Grid.Column="1"
            Background="{ThemeResource AveliaCardBackgroundBrush}"
            BorderBrush="{ThemeResource AveliaSurfaceStrokeBrush}"
            BorderThickness="1,0,0,0"
        >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- PR header -->
            <controls:PrHeader
                Grid.Row="0"
                AutomationProperties.AutomationId="PrHeader"
                ViewModel="{x:Bind ViewModel.PrPane, Mode=OneWay}"
            />

            <!-- Hairline + Changes/Files pivot strip. The strip ships as a
                 design affordance for Chunk 10's real backend split between
                 workspace diff and PR diff; today both pivots render the same
                 file list, so the SelectionChanged handler just updates
                 ViewModel.PrPane.ActiveTab without re-querying. The shape is
                 right for the eventual split. -->
            <Border
                Grid.Row="1"
                BorderBrush="{ThemeResource AveliaDividerStrokeBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,4,12,0"
            >
                <SelectorBar
                    AutomationProperties.AutomationId="PrPaneTabStrip"
                    AutomationProperties.Name="Changes or files"
                    SelectionChanged="OnPrPaneTabSelectionChanged"
                >
                    <SelectorBarItem AutomationProperties.AutomationId="PrPaneChangesTab" Text="Changes" IsSelected="True" />
                    <SelectorBarItem AutomationProperties.AutomationId="PrPaneFilesTab" Text="Files" />
                </SelectorBar>
            </Border>

            <!-- File list -->
            <controls:FileChangeList
                Grid.Row="2"
                AutomationProperties.AutomationId="FileChangeList"
                Files="{x:Bind ViewModel.PrPane.Files, Mode=OneWay}"
            />

            <!-- Terminal panel — sticky bottom -->
            <controls:TerminalPanel
                Grid.Row="3"
                AutomationProperties.AutomationId="TerminalPanel"
                ViewModel="{x:Bind ViewModel.Terminal, Mode=OneWay}"
            />
        </Grid>
    </Grid>
</Page>
