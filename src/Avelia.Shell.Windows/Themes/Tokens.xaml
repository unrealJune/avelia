<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
    <!--
        Avelia design tokens. One SolidColorBrush per CSS variable in the
        "WinUI Conductor — Fluent" design (styles.css). Light and Dark
        variants live in ThemeDictionaries so SystemTheme + ElementTheme
        switching is automatic.

        Hex format is #AARRGGBB (alpha first). The alphas mirror the source
        rgba() values converted to byte (e.g. 0.0512 → 0x0D).
    -->
    <ResourceDictionary.ThemeDictionaries>
        <!-- =============================== Dark =============================== -->
        <ResourceDictionary x:Key="Default">
            <!-- Mica & layers -->
            <SolidColorBrush x:Key="AveliaMicaBaseBrush" Color="#1F1F1F" />
            <SolidColorBrush x:Key="AveliaMicaTintBrush" Color="#05FFFFFF" />
            <SolidColorBrush x:Key="AveliaLayerFillDefaultBrush" Color="#0DFFFFFF" />
            <SolidColorBrush x:Key="AveliaLayerFillSecondaryBrush" Color="#15FFFFFF" />
            <SolidColorBrush x:Key="AveliaLayerFillTertiaryBrush" Color="#0BFFFFFF" />
            <SolidColorBrush x:Key="AveliaCardBackgroundBrush" Color="#0DFFFFFF" />
            <SolidColorBrush x:Key="AveliaCardBackgroundSecondaryBrush" Color="#21000000" />
            <SolidColorBrush x:Key="AveliaSurfaceStrokeBrush" Color="#12FFFFFF" />
            <SolidColorBrush x:Key="AveliaDividerStrokeBrush" Color="#15FFFFFF" />

            <!-- Control fills -->
            <SolidColorBrush x:Key="AveliaControlFillDefaultBrush" Color="#0FFFFFFF" />
            <SolidColorBrush x:Key="AveliaControlFillSecondaryBrush" Color="#15FFFFFF" />
            <SolidColorBrush x:Key="AveliaControlFillTertiaryBrush" Color="#08FFFFFF" />
            <SolidColorBrush x:Key="AveliaControlFillDisabledBrush" Color="#0BFFFFFF" />
            <SolidColorBrush x:Key="AveliaControlStrokeDefaultBrush" Color="#18FFFFFF" />
            <SolidColorBrush x:Key="AveliaControlStrokeSecondaryBrush" Color="#12FFFFFF" />

            <!-- Subtle fills (used by selected nav items, hover rows) -->
            <SolidColorBrush x:Key="AveliaSubtleFillSecondaryBrush" Color="#0FFFFFFF" />
            <SolidColorBrush x:Key="AveliaSubtleFillTertiaryBrush" Color="#0BFFFFFF" />

            <!-- Text -->
            <SolidColorBrush x:Key="AveliaTextPrimaryBrush" Color="#DCFFFFFF" />
            <SolidColorBrush x:Key="AveliaTextSecondaryBrush" Color="#8BFFFFFF" />
            <SolidColorBrush x:Key="AveliaTextTertiaryBrush" Color="#5DFFFFFF" />
            <SolidColorBrush x:Key="AveliaTextDisabledBrush" Color="#5DFFFFFF" />
            <SolidColorBrush x:Key="AveliaTextOnAccentBrush" Color="#000000" />

            <!-- Accent (Windows 11 dark default — Sky Blue) -->
            <SolidColorBrush x:Key="AveliaAccentDefaultBrush" Color="#4CC2FF" />
            <SolidColorBrush x:Key="AveliaAccentSecondaryBrush" Color="#47B1E8" />
            <SolidColorBrush x:Key="AveliaAccentTertiaryBrush" Color="#408FB5" />
            <SolidColorBrush x:Key="AveliaAccentTextBrush" Color="#99EBFF" />

            <!-- Semantic -->
            <SolidColorBrush x:Key="AveliaSuccessBrush" Color="#6CCB5F" />
            <SolidColorBrush x:Key="AveliaSuccessBgBrush" Color="#1A6CCB5F" />
            <SolidColorBrush x:Key="AveliaWarningBrush" Color="#FCE100" />
            <SolidColorBrush x:Key="AveliaWarningBgBrush" Color="#1AFCE100" />
            <SolidColorBrush x:Key="AveliaDangerBrush" Color="#FF99A4" />
            <SolidColorBrush x:Key="AveliaDangerBgBrush" Color="#1AFF99A4" />
            <SolidColorBrush x:Key="AveliaInfoBrush" Color="#4CC2FF" />

            <!-- Diff (used by PR review viewer) -->
            <SolidColorBrush x:Key="AveliaDiffAddBgBrush" Color="#1F6CCB5F" />
            <SolidColorBrush x:Key="AveliaDiffAddStrongBrush" Color="#476CCB5F" />
            <SolidColorBrush x:Key="AveliaDiffDelBgBrush" Color="#1FFF6363" />
            <SolidColorBrush x:Key="AveliaDiffDelStrongBrush" Color="#4DFF6363" />

            <!-- Caption / chrome -->
            <SolidColorBrush x:Key="AveliaCaptionHoverBrush" Color="#0FFFFFFF" />
            <SolidColorBrush x:Key="AveliaCaptionCloseHoverBrush" Color="#C42B1C" />
            <SolidColorBrush x:Key="AveliaCaptionCloseHoverFgBrush" Color="#FFFFFF" />

            <!-- Merge button gradient — styles-app.css :: .merge-btn -->
            <LinearGradientBrush
                x:Key="AveliaMergeButtonBackgroundBrush"
                StartPoint="0,0"
                EndPoint="0,1"
            >
                <GradientStop Offset="0.0" Color="#2C8C2C" />
                <GradientStop Offset="1.0" Color="#1F6B1F" />
            </LinearGradientBrush>
        </ResourceDictionary>

        <!-- =============================== Light ============================== -->
        <ResourceDictionary x:Key="Light">
            <!-- Mica & layers -->
            <SolidColorBrush x:Key="AveliaMicaBaseBrush" Color="#F3F3F3" />
            <SolidColorBrush x:Key="AveliaMicaTintBrush" Color="#66FFFFFF" />
            <SolidColorBrush x:Key="AveliaLayerFillDefaultBrush" Color="#B3FFFFFF" />
            <SolidColorBrush x:Key="AveliaLayerFillSecondaryBrush" Color="#80F9F9F9" />
            <SolidColorBrush x:Key="AveliaLayerFillTertiaryBrush" Color="#4DFFFFFF" />
            <SolidColorBrush x:Key="AveliaCardBackgroundBrush" Color="#B3FFFFFF" />
            <SolidColorBrush x:Key="AveliaCardBackgroundSecondaryBrush" Color="#80F6F6F6" />
            <SolidColorBrush x:Key="AveliaSurfaceStrokeBrush" Color="#0F000000" />
            <SolidColorBrush x:Key="AveliaDividerStrokeBrush" Color="#15000000" />

            <!-- Control fills -->
            <SolidColorBrush x:Key="AveliaControlFillDefaultBrush" Color="#B3FFFFFF" />
            <SolidColorBrush x:Key="AveliaControlFillSecondaryBrush" Color="#80F9F9F9" />
            <SolidColorBrush x:Key="AveliaControlFillTertiaryBrush" Color="#4DF9F9F9" />
            <SolidColorBrush x:Key="AveliaControlFillDisabledBrush" Color="#4DF9F9F9" />
            <SolidColorBrush x:Key="AveliaControlStrokeDefaultBrush" Color="#0F000000" />
            <SolidColorBrush x:Key="AveliaControlStrokeSecondaryBrush" Color="#29000000" />

            <!-- Subtle fills -->
            <SolidColorBrush x:Key="AveliaSubtleFillSecondaryBrush" Color="#0A000000" />
            <SolidColorBrush x:Key="AveliaSubtleFillTertiaryBrush" Color="#06000000" />

            <!-- Text -->
            <SolidColorBrush x:Key="AveliaTextPrimaryBrush" Color="#E4000000" />
            <SolidColorBrush x:Key="AveliaTextSecondaryBrush" Color="#9B000000" />
            <SolidColorBrush x:Key="AveliaTextTertiaryBrush" Color="#72000000" />
            <SolidColorBrush x:Key="AveliaTextDisabledBrush" Color="#5C000000" />
            <SolidColorBrush x:Key="AveliaTextOnAccentBrush" Color="#FFFFFF" />

            <!-- Accent (Windows 11 light default — Default Blue) -->
            <SolidColorBrush x:Key="AveliaAccentDefaultBrush" Color="#005FB8" />
            <SolidColorBrush x:Key="AveliaAccentSecondaryBrush" Color="#1A6BBE" />
            <SolidColorBrush x:Key="AveliaAccentTertiaryBrush" Color="#3982C4" />
            <SolidColorBrush x:Key="AveliaAccentTextBrush" Color="#003E92" />

            <!-- Semantic -->
            <SolidColorBrush x:Key="AveliaSuccessBrush" Color="#0F7B0F" />
            <SolidColorBrush x:Key="AveliaSuccessBgBrush" Color="#140F7B0F" />
            <SolidColorBrush x:Key="AveliaWarningBrush" Color="#9D5D00" />
            <SolidColorBrush x:Key="AveliaWarningBgBrush" Color="#149D5D00" />
            <SolidColorBrush x:Key="AveliaDangerBrush" Color="#C42B1C" />
            <SolidColorBrush x:Key="AveliaDangerBgBrush" Color="#0FC42B1C" />
            <SolidColorBrush x:Key="AveliaInfoBrush" Color="#005FB8" />

            <!-- Diff -->
            <SolidColorBrush x:Key="AveliaDiffAddBgBrush" Color="#140F7B0F" />
            <SolidColorBrush x:Key="AveliaDiffAddStrongBrush" Color="#380F7B0F" />
            <SolidColorBrush x:Key="AveliaDiffDelBgBrush" Color="#12C42B1C" />
            <SolidColorBrush x:Key="AveliaDiffDelStrongBrush" Color="#38C42B1C" />

            <!-- Caption / chrome -->
            <SolidColorBrush x:Key="AveliaCaptionHoverBrush" Color="#0F000000" />
            <SolidColorBrush x:Key="AveliaCaptionCloseHoverBrush" Color="#C42B1C" />
            <SolidColorBrush x:Key="AveliaCaptionCloseHoverFgBrush" Color="#FFFFFF" />

            <!-- Merge button gradient -->
            <LinearGradientBrush
                x:Key="AveliaMergeButtonBackgroundBrush"
                StartPoint="0,0"
                EndPoint="0,1"
            >
                <GradientStop Offset="0.0" Color="#2C8C2C" />
                <GradientStop Offset="1.0" Color="#1F6B1F" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- Theme-independent corner radii (Fluent design uses 4 / 6 / 8). -->
    <CornerRadius x:Key="AveliaCornerRadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="AveliaCornerRadiusMedium">6</CornerRadius>
    <CornerRadius x:Key="AveliaCornerRadiusLarge">8</CornerRadius>
    <CornerRadius x:Key="AveliaCornerRadiusPill">999</CornerRadius>

    <!-- Common thicknesses -->
    <Thickness x:Key="AveliaHairlineThickness">1</Thickness>
</ResourceDictionary>
