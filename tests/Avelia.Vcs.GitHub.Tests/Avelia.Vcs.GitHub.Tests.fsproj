<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <GenerateProgramFile>true</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="GitHubTests.fs" />
    <Compile Include="AccessTokenSerializationTests.fs" />
    <Compile Include="OctokitHttpStub.fs" />
    <Compile Include="DeviceFlowTests.fs" />
    <Compile Include="AuthTests.fs" />
    <Compile Include="CredentialStoreTests.fs" />
    <Compile Include="ResponseCacheTests.fs" />
    <Compile Include="RateLimitGuardTests.fs" />
    <Compile Include="ApiClientTests.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.Core" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="FsUnit.xUnit" />
    <PackageReference Include="FsCheck.Xunit" />
    <ProjectReference Include="..\..\src\Avelia.Vcs.GitHub\Avelia.Vcs.GitHub.fsproj" />
  </ItemGroup>

</Project>
